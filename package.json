  "author": "Ahmad Arja",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Ahmad-Arja/gymlog-api/issues"
  },
  "homepage": "https://github.com/Ahmad-Arja/gymlog-api#readme",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.6",
    "nodemon": "^3.1.9",
    "supertest": "^7.2.2",
    "vitest": "^4.1.6"
  },
  "vitest": {
    "environment": "node"
